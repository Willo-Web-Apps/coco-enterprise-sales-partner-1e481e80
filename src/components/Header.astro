---
---
<header class="sticky top-0 z-50 border-b border-white/5 bg-surface-50/85 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-6">

    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-2.5 group flex-shrink-0" aria-label="EdgeSales — Home">
      <!-- Animated double-bar brand mark -->
      <span class="flex flex-col gap-[4px]" aria-hidden="true">
        <span class="block w-5 h-[2.5px] bg-brand-500 rounded-full transition-all duration-200 group-hover:w-6"></span>
        <span class="block w-3 h-[2.5px] bg-brand-500/45 rounded-full transition-all duration-200 group-hover:w-5"></span>
      </span>
      <span class="font-display text-[1.25rem] tracking-[0.14em] text-surface-950 uppercase">
        Edge<span class="text-brand-500">Sales</span>
      </span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-7 flex-1 justify-center">
      <a
        href="#how-it-works"
        class="text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors tracking-wide"
      >
        How It Works
      </a>
      <a
        href="#proof"
        class="text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors tracking-wide"
      >
        Results
      </a>
      <a
        href="#use-cases"
        class="text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors tracking-wide"
      >
        Use Cases
      </a>
      <a
        href="https://coco.xyz"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-surface-700 hover:text-brand-500 transition-colors tracking-wide inline-flex items-center gap-1.5"
        aria-label="COCO AI — opens in new tab"
      >
        COCO AI
        <svg class="w-3 h-3 opacity-55" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>

    <!-- Desktop CTA button -->
    <a
      href="mailto:info@edgeof.xyz?subject=Free%20Automation%20Assessment%20Request"
      class="hidden md:inline-flex btn-primary text-xs px-5 py-2.5 flex-shrink-0"
      style="min-height: 40px;"
    >
      Free Assessment
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>

    <!-- Mobile CTA — large enough touch target -->
    <a
      href="mailto:info@edgeof.xyz?subject=Free%20Automation%20Assessment%20Request"
      class="md:hidden btn-primary text-xs px-4 py-2.5"
      style="min-height: 44px;"
    >
      Free Assessment
    </a>

  </nav>
</header>
