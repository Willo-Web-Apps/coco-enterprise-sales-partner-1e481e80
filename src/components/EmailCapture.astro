---
interface Props {
  source?: string;
  label?: string;
  placeholder?: string;
  buttonText?: string;
}

const {
  source = 'homepage-footer',
  label = 'Get AI Automation Insights — free, weekly.',
  placeholder = 'your@company.com',
  buttonText = 'Subscribe',
} = Astro.props;
---

<div class="email-capture-widget w-full">
  <p class="text-xs font-semibold tracking-widest text-surface-800 uppercase mb-3">{label}</p>
  <form
    class="flex w-full max-w-sm"
    data-source={source}
    id={`email-capture-${source}`}
    novalidate
  >
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      class="email-input"
      placeholder={placeholder}
      aria-label="Email address"
    />
    <button type="submit" class="email-submit">
      {buttonText}
    </button>
  </form>
  <p class="success-msg hidden mt-2 text-xs text-brand-400 font-medium tracking-wide">
    ✓ You're in. Insights incoming.
  </p>
  <p class="error-msg hidden mt-2 text-xs text-red-400 font-medium">
    Please enter a valid email address.
  </p>
  <p class="mt-2 text-xs text-surface-700">No spam. Unsubscribe anytime.</p>
</div>

<script>
  // Inline script for the email capture widget
  document.querySelectorAll('form[data-source]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const f = e.currentTarget as HTMLFormElement;
      const emailInput = f.querySelector('input[name="email"]') as HTMLInputElement;
      const successMsg = f.parentElement?.querySelector('.success-msg') as HTMLElement;
      const errorMsg   = f.parentElement?.querySelector('.error-msg')   as HTMLElement;

      if (!emailInput || !emailInput.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value)) {
        errorMsg?.classList.remove('hidden');
        successMsg?.classList.add('hidden');
        return;
      }

      // Hide error, show success
      errorMsg?.classList.add('hidden');

      // Log to console with source attribution (replace with real endpoint as needed)
      console.log('[EmailCapture]', {
        email: emailInput.value,
        source: f.dataset.source,
        timestamp: new Date().toISOString(),
      });

      // Show success state
      f.classList.add('hidden');
      successMsg?.classList.remove('hidden');
    });
  });
</script>
