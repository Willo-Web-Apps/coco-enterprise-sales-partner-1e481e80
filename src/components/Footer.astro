---
import EmailCapture from './EmailCapture.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-surface-50 pt-16 pb-10 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Top grid: brand | nav | services | newsletter -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 xl:gap-14 mb-14">

      <!-- Brand column -->
      <div class="md:col-span-4">
        <a href="/" class="flex items-center gap-2.5 mb-5 group w-fit" aria-label="EdgeSales — Home">
          <span class="flex flex-col gap-[4px]" aria-hidden="true">
            <span class="block w-5 h-[2.5px] bg-brand-500 rounded-full"></span>
            <span class="block w-3 h-[2.5px] bg-brand-500/45 rounded-full"></span>
          </span>
          <span class="font-display text-[1.2rem] tracking-[0.14em] text-surface-950 uppercase">
            Edge<span class="text-brand-500">Sales</span>
          </span>
        </a>

        <p class="text-sm text-surface-800 leading-relaxed mb-5 max-w-[280px]">
          AI automation advisory by Edge of Company. We map your workflows, identify high-ROI automation opportunities, and connect you with COCO AI agent teams that work around the clock.
        </p>

        <!-- Contact -->
        <a
          href="mailto:info@edgeof.xyz"
          class="inline-flex items-center gap-2 text-sm text-surface-800 hover:text-brand-400 transition-colors group"
        >
          <svg class="w-3.5 h-3.5 text-surface-700 group-hover:text-brand-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          info@edgeof.xyz
        </a>

        <div class="mt-2">
          <a
            href="https://www.edgeof.xyz"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-surface-700 hover:text-surface-900 transition-colors"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253M3 12a8.959 8.959 0 0 0 .284 2.253" />
            </svg>
            edgeof.xyz ↗
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div class="md:col-span-2">
        <p class="text-xs font-bold tracking-[0.2em] text-surface-700 uppercase mb-5">Navigate</p>
        <ul class="space-y-3 text-sm">
          <li><a href="#how-it-works" class="text-surface-800 hover:text-surface-950 transition-colors">How It Works</a></li>
          <li><a href="#proof" class="text-surface-800 hover:text-surface-950 transition-colors">Results</a></li>
          <li><a href="#use-cases" class="text-surface-800 hover:text-surface-950 transition-colors">Use Cases</a></li>
          <li><a href="#cta" class="text-surface-800 hover:text-surface-950 transition-colors">Book Assessment</a></li>
          <li>
            <a
              href="https://www.edgeof.xyz"
              target="_blank"
              rel="noopener noreferrer"
              class="text-surface-800 hover:text-surface-950 transition-colors"
            >
              Edge of Company ↗
            </a>
          </li>
        </ul>
      </div>

      <!-- Services we automate -->
      <div class="md:col-span-2">
        <p class="text-xs font-bold tracking-[0.2em] text-surface-700 uppercase mb-5">We Automate</p>
        <ul class="space-y-3 text-sm text-surface-800">
          <li>Customer Support</li>
          <li>Sales Outreach</li>
          <li>Finance &amp; Reporting</li>
          <li>HR &amp; Onboarding</li>
          <li>Operations &amp; Logistics</li>
          <li>Code Review &amp; Dev</li>
        </ul>
      </div>

      <!-- Newsletter capture -->
      <div class="md:col-span-4">
        <p class="text-xs font-bold tracking-[0.2em] text-surface-700 uppercase mb-4">AI Automation Insights</p>
        <p class="text-sm text-surface-800 leading-relaxed mb-5">
          Weekly playbooks, real deployment outcomes, and practical AI guides — written for business owners, COOs, and operations leaders.
        </p>
        <EmailCapture
          source="homepage-footer"
          label=""
          placeholder="your@company.com"
          buttonText="Subscribe"
        />
      </div>

    </div>

    <!-- Divider -->
    <div class="section-separator mb-8"></div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <p class="text-xs text-surface-700 leading-relaxed">
        &copy; {year} EdgeSales ·
        <a href="https://www.edgeof.xyz" target="_blank" rel="noopener noreferrer" class="hover:text-brand-400 transition-colors">Edge of Company</a>
        &nbsp;· All rights reserved
      </p>

      <!-- Powered by COCO AI — always visible, always contextual -->
      <a
        href="https://coco.xyz"
        target="_blank"
        rel="noopener noreferrer"
        class="powered-badge self-start sm:self-auto"
        aria-label="Powered by COCO AI — opens coco.xyz in a new tab"
      >
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
        </svg>
        Powered by COCO AI
      </a>
    </div>

  </div>
</footer>
