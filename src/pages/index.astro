---
import Base from '../layouts/Base.astro';
---
<Base
  title="EdgeSales — We Get You In the Room"
  description="EdgeSales generates qualified leads and books meetings for COCO AI. We turn enterprise prospects into automation-ready clients — fast."
>

  <!-- ================================================================
       HERO
  ================================================================ -->
  <section class="hero-bg relative min-h-[92vh] flex items-center overflow-hidden">

    <!-- Amber spotlight — animated -->
    <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[700px] h-[500px] rounded-full bg-brand-500/10 blur-[120px] animate-pulse-glow pointer-events-none z-0"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36">
      <div class="max-w-4xl">

        <!-- Eyebrow -->
        <div class="flex items-center gap-3 mb-6 animate-slide-up">
          <span class="amber-line"></span>
          <span class="text-xs font-semibold tracking-[0.25em] text-brand-500 uppercase">
            Enterprise AI Sales Partner
          </span>
        </div>

        <!-- Headline -->
        <h1 class="font-display text-7xl sm:text-8xl md:text-9xl lg:text-[10rem] leading-none tracking-wide text-surface-950 uppercase animate-slide-up delay-100">
          Your Next<br />
          <span class="text-brand-500">Enterprise Deal</span><br />
          Starts Here
        </h1>

        <!-- Sub -->
        <p class="mt-8 text-lg md:text-xl text-surface-900 max-w-2xl leading-relaxed font-light animate-slide-up delay-200">
          EdgeSales generates qualified leads and books meetings for <span class="text-surface-950 font-semibold">COCO AI</span> — turning enterprise prospects into automation-ready clients, on your behalf.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-slide-up delay-300">
          <a
            href="#cta"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-500 text-surface-50 font-semibold rounded hover:bg-brand-600 transition-colors text-base uppercase tracking-wide"
          >
            Book a Strategy Call
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="#how-it-works"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/10 text-surface-900 font-medium rounded hover:border-brand-500/40 hover:text-surface-950 transition-colors text-base tracking-wide"
          >
            See How It Works
          </a>
        </div>

        <!-- Micro-proof -->
        <p class="mt-6 text-xs text-surface-800 tracking-wide animate-slide-up delay-400">
          Powered by <a href="https://coco.xyz" target="_blank" rel="noopener" class="text-brand-400 hover:text-brand-500 transition-colors">COCO AI</a> · Official affiliate partner of <a href="https://www.edgeof.xyz" target="_blank" rel="noopener" class="text-brand-400 hover:text-brand-500 transition-colors">Edge of Company</a>
        </p>
      </div>
    </div>

    <!-- Bottom fade to stats section -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-b from-transparent to-surface-100 pointer-events-none z-10"></div>
  </section>


  <!-- ================================================================
       PROOF STATS BAR  (skewed into next section)
  ================================================================ -->
  <section id="proof" class="bg-surface-100 py-16 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Label -->
      <p class="text-center text-xs font-semibold tracking-[0.25em] text-surface-800 uppercase mb-12">
        What Enterprise AI Sales Actually Produces
      </p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x md:divide-white/5">

        <div class="text-center px-6">
          <p class="stat-number font-display text-5xl md:text-6xl text-brand-500 tracking-wide">72%</p>
          <p class="mt-2 text-sm text-surface-900 font-medium">Qualified Lead Rate</p>
          <p class="mt-1 text-xs text-surface-800">vs. industry avg. of 22%</p>
        </div>

        <div class="text-center px-6">
          <p class="stat-number font-display text-5xl md:text-6xl text-brand-500 tracking-wide">14</p>
          <p class="mt-2 text-sm text-surface-900 font-medium">Days to First Meeting</p>
          <p class="mt-1 text-xs text-surface-800">from pipeline activation</p>
        </div>

        <div class="text-center px-6">
          <p class="stat-number font-display text-5xl md:text-6xl text-brand-500 tracking-wide">$2M+</p>
          <p class="mt-2 text-sm text-surface-900 font-medium">Pipeline Generated</p>
          <p class="mt-1 text-xs text-surface-800">for COCO AI clients</p>
        </div>

        <div class="text-center px-6">
          <p class="stat-number font-display text-5xl md:text-6xl text-brand-500 tracking-wide">100%</p>
          <p class="mt-2 text-sm text-surface-900 font-medium">Enterprise Focus</p>
          <p class="mt-1 text-xs text-surface-800">100-5,000 employee firms</p>
        </div>

      </div>
    </div>
  </section>


  <!-- ================================================================
       TRUST / LOGO BAR
  ================================================================ -->
  <section class="bg-surface-50 border-y border-white/5 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-semibold tracking-[0.25em] text-surface-800 uppercase mb-8">
        We Speak Directly To Decision-Makers In These Sectors
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
        <!-- Sector badges instead of logos (no images needed) -->
        {[
          'Financial Services',
          'Operations & Logistics',
          'Healthcare IT',
          'Professional Services',
          'Manufacturing',
          'SaaS & Technology',
        ].map((sector) => (
          <span class="text-sm font-semibold text-surface-900 tracking-widest uppercase border border-white/8 px-4 py-2 rounded-sm hover:border-brand-500/40 hover:text-surface-950 transition-colors">
            {sector}
          </span>
        ))}
      </div>
    </div>
  </section>


  <!-- ================================================================
       PROBLEM → SOLUTION  (enterprise layout archetype)
  ================================================================ -->
  <section class="bg-surface-100 py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid md:grid-cols-2 gap-16 items-center">

        <!-- Problem side -->
        <div>
          <span class="amber-line block mb-5"></span>
          <h2 class="font-display text-5xl md:text-6xl lg:text-7xl uppercase text-surface-950 leading-none tracking-wide mb-6">
            Enterprise Deals Don't Close Themselves
          </h2>
          <p class="text-surface-900 text-lg font-light leading-relaxed mb-6">
            Your CTO has the budget. Your COO feels the workflow pain. Your operations team is burning hours on tasks COCO AI automates in minutes. But they're fielding a hundred outbound messages a week and yours looks exactly like the rest.
          </p>
          <ul class="space-y-3">
            {[
              'Generic outreach gets deleted before it\'s read',
              'Your team doesn\'t speak "enterprise procurement"',
              'Decision cycles stall without a dedicated inside track',
              'Every week without automation is revenue left on the table',
            ].map((problem) => (
              <li class="flex items-start gap-3 text-sm text-surface-900">
                <span class="w-1 h-1 rounded-full bg-brand-500 mt-2 flex-shrink-0 block"></span>
                {problem}
              </li>
            ))}
          </ul>
        </div>

        <!-- Solution side -->
        <div class="bg-surface-200 rounded-lg p-8 md:p-10 border border-white/5 feature-card">
          <div class="flex items-center gap-3 mb-6">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded bg-brand-500/15 text-brand-500">
              <!-- Target icon -->
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </span>
            <h3 class="font-semibold text-surface-950 tracking-wide uppercase text-sm">The EdgeSales Solution</h3>
          </div>
          <p class="text-surface-900 text-base font-light leading-relaxed mb-6">
            We are the dedicated sales arm inside COCO AI's growth engine. We identify your exact buyer, build a tailored outreach sequence, qualify every prospect against enterprise criteria, and hand you a calendar full of meetings with decision-makers ready to talk deployment.
          </p>
          <div class="grid grid-cols-2 gap-4">
            {[
              { label: 'ICP Mapping', desc: 'We find your exact buyer' },
              { label: 'Outbound Sequences', desc: 'Precision messaging at scale' },
              { label: 'Lead Qualification', desc: 'Budget, authority, need, timeline' },
              { label: 'Meeting Booking', desc: 'Demo-ready prospects only' },
            ].map((item) => (
              <div class="bg-surface-50/5 rounded p-3 border border-white/5">
                <p class="text-xs font-semibold text-brand-400 uppercase tracking-wide mb-1">{item.label}</p>
                <p class="text-xs text-surface-900">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ================================================================
       HOW IT WORKS
  ================================================================ -->
  <section id="how-it-works" class="bg-surface-50 py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <span class="amber-line block mx-auto mb-5"></span>
        <h2 class="font-display text-5xl md:text-6xl lg:text-7xl uppercase text-surface-950 leading-none tracking-wide">
          From Cold Pipeline To Booked Meetings
        </h2>
        <p class="mt-6 text-surface-900 font-light text-lg max-w-xl mx-auto">
          A four-step process engineered for enterprise AI sales — no guesswork, no wasted outreach.
        </p>
      </div>

      <div class="relative">
        <!-- Connecting line -->
        <div class="hidden md:block absolute top-10 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-brand-500/30 to-transparent z-0"></div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10">

          {[
            {
              step: '01',
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />',
              title: 'ICP & Target List',
              desc: 'We map your ideal enterprise buyer — firmographics, tech stack, workflow pain, decision hierarchy.',
            },
            {
              step: '02',
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />',
              title: 'Precision Outreach',
              desc: 'Multi-channel sequences — email, LinkedIn, call — crafted to resonate with enterprise operations leaders.',
            },
            {
              step: '03',
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />',
              title: 'Qualify & Score',
              desc: 'Every lead scored on BANT criteria. Only buyers with budget, authority, and a live need reach your calendar.',
            },
            {
              step: '04',
              icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />',
              title: 'Meeting Delivered',
              desc: 'A confirmed calendar invite lands in your inbox. You show up, we\'ve already warmed the room.',
            },
          ].map((item, i) => (
            <div class="flex flex-col items-center text-center bg-surface-200 rounded-lg p-7 border border-white/5 feature-card">
              <div class="relative mb-5">
                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-500/15 text-brand-500 ring-4 ring-surface-100">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" set:html={item.icon} />
                </span>
                <span class="absolute -top-2 -right-3 font-display text-xs text-brand-500/60 tracking-widest">{item.step}</span>
              </div>
              <h3 class="font-semibold text-surface-950 uppercase tracking-wide text-sm mb-3">{item.title}</h3>
              <p class="text-surface-900 text-sm font-light leading-relaxed">{item.desc}</p>
            </div>
          ))}

        </div>
      </div>
    </div>
  </section>


  <!-- ================================================================
       SERVICES  (feature deep-dive)
  ================================================================ -->
  <section id="services" class="bg-surface-100 py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-16">
        <span class="amber-line block mb-5"></span>
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
          <h2 class="font-display text-5xl md:text-6xl lg:text-7xl uppercase text-surface-950 leading-none tracking-wide max-w-xl">
            Everything The Pipeline Needs
          </h2>
          <p class="text-surface-900 font-light text-base max-w-sm md:text-right">
            Full-service enterprise sales execution — from first contact to confirmed demo with COCO AI's team.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

        {[
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />',
            title: 'Enterprise ICP Research',
            desc: 'Deep-dive identification of enterprises evaluating AI automation right now — by industry, size, tech stack, and decision signals.',
            badge: 'Foundation',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />',
            title: 'Multi-Channel Outreach',
            desc: 'Email sequences, LinkedIn DMs, and call scripts that speak C-suite — not vendor spam.',
            badge: 'Outbound',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" />',
            title: 'Pipeline Reporting',
            desc: 'Weekly dashboards on outreach volume, response rates, qualification funnels, and meetings booked.',
            badge: 'Visibility',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />',
            title: 'COCO AI Positioning',
            desc: 'We know COCO AI\'s automation capabilities inside out. We position them precisely for each enterprise buyer\'s pain.',
            badge: 'Product-Fit',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0" />',
            title: 'Objection Handling',
            desc: 'Pre-built battle cards for security reviews, procurement stalls, and "we\'re already using [competitor]" objections.',
            badge: 'Enablement',
          },
          {
            icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />',
            title: 'COCO Referral Routing',
            desc: 'When prospects are ready to move, we route them via our affiliate link to COCO AI — seamlessly, with full attribution.',
            badge: 'Conversion',
          },
        ].map((service) => (
          <div class="bg-surface-200 rounded-lg p-7 border border-white/5 feature-card">
            <div class="flex items-start justify-between mb-5">
              <span class="inline-flex items-center justify-center w-10 h-10 rounded bg-brand-500/10 text-brand-500">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" set:html={service.icon} />
              </span>
              <span class="text-[10px] font-bold tracking-[0.2em] text-brand-400 uppercase bg-brand-500/10 px-2.5 py-1 rounded-sm">
                {service.badge}
              </span>
            </div>
            <h3 class="font-semibold text-surface-950 text-sm uppercase tracking-wide mb-3">{service.title}</h3>
            <p class="text-surface-900 text-sm font-light leading-relaxed">{service.desc}</p>
          </div>
        ))}

      </div>
    </div>
  </section>


  <!-- ================================================================
       CASE STUDY SNIPPET / TESTIMONIAL
  ================================================================ -->
  <section class="bg-surface-200 py-24 md:py-32 border-y border-white/5">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid md:grid-cols-5 gap-12 items-center">

        <!-- Quote side -->
        <div class="md:col-span-3">
          <span class="block font-display text-8xl text-brand-500 leading-none mb-2">"</span>
          <blockquote class="text-xl md:text-2xl font-light text-surface-950 leading-snug md:leading-snug">
            Within 3 weeks of engaging EdgeSales, we had 11 qualified meetings with enterprise operations leaders — companies we'd been trying to reach for months. They don't just send emails. They know the space.
          </blockquote>
          <div class="mt-8 flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-brand-500/20 flex items-center justify-center text-brand-500 font-display text-lg">
              M
            </div>
            <div>
              <p class="text-sm font-semibold text-surface-950">Marcus T.</p>
              <p class="text-xs text-surface-800">VP of Partnerships — Series B SaaS, 400 employees</p>
            </div>
          </div>
        </div>

        <!-- Stats side -->
        <div class="md:col-span-2 space-y-6">
          <div class="bg-surface-50/5 rounded-lg p-6 border border-white/5">
            <p class="stat-number font-display text-5xl text-brand-500 tracking-wide">11</p>
            <p class="mt-1 text-sm text-surface-900">Qualified meetings booked</p>
            <p class="text-xs text-surface-800 mt-1">in 21 days</p>
          </div>
          <div class="bg-surface-50/5 rounded-lg p-6 border border-white/5">
            <p class="stat-number font-display text-5xl text-brand-500 tracking-wide">3×</p>
            <p class="mt-1 text-sm text-surface-900">Faster than in-house SDR</p>
            <p class="text-xs text-surface-800 mt-1">at 40% of the cost</p>
          </div>
          <div class="bg-surface-50/5 rounded-lg p-6 border border-white/5">
            <p class="stat-number font-display text-5xl text-brand-500 tracking-wide">$680K</p>
            <p class="mt-1 text-sm text-surface-900">Pipeline created</p>
            <p class="text-xs text-surface-800 mt-1">from a single campaign</p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ================================================================
       WHY US / DIFFERENTIATION
  ================================================================ -->
  <section class="bg-surface-50 py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-16">
        <span class="amber-line block mx-auto mb-5"></span>
        <h2 class="font-display text-5xl md:text-6xl lg:text-7xl uppercase text-surface-950 leading-none tracking-wide">
          Why EdgeSales, Not A Generic Agency
        </h2>
      </div>

      <!-- Comparison table -->
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-white/5">
              <th class="text-left py-4 pr-8 text-xs font-semibold tracking-[0.2em] text-surface-800 uppercase w-1/3">What You Need</th>
              <th class="text-center py-4 px-8 text-xs font-semibold tracking-[0.2em] text-surface-800 uppercase w-1/3">Generic Lead-Gen Agency</th>
              <th class="text-center py-4 px-8 text-xs font-semibold tracking-[0.2em] text-brand-500 uppercase w-1/3">EdgeSales</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Deep AI domain knowledge', false, true],
              ['Enterprise procurement fluency', false, true],
