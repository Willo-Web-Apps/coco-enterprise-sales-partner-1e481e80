---
import Base from '../layouts/Base.astro';
---
<Base
  title="EdgeSales — Your Business Runs Itself. We Show You How."
  description="Edge of Company maps your operations, identifies automation wins, and connects you with COCO AI agent teams that work 24/7 — starting in days. Book your free automation assessment."
>

  <!-- ================================================================
       HERO — Command Center
       Asymmetric layout: headline left-heavy, micro-proof below
  ================================================================ -->
  <section class="hero-bg relative min-h-[96vh] flex items-center">

    <!-- Grid overlay: subtle ops-room mesh -->
    <div class="grid-overlay" aria-hidden="true"></div>

    <!-- Animated amber orb — upper-left, matches ::before spotlight -->
    <div
      aria-hidden="true"
      class="absolute top-[5%] left-[4%] w-[520px] h-[420px] rounded-full pointer-events-none z-[2] animate-pulse-glow"
      style="background: radial-gradient(ellipse 70% 60% at 30% 40%, oklch(0.78 0.17 75 / 0.12) 0%, transparent 68%); filter: blur(55px);"
    ></div>

    <!-- Secondary warm orb — lower right -->
    <div
      aria-hidden="true"
      class="absolute bottom-[10%] right-[8%] w-[320px] h-[260px] rounded-full pointer-events-none z-[2] animate-pulse-glow"
      style="background: radial-gradient(ellipse at center, oklch(0.67 0.14 68 / 0.09) 0%, transparent 70%); filter: blur(50px); animation-delay: 3.5s;"
    ></div>

    <!-- Hero content — deliberately left-heavy, not centred -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-20 pb-32 md:pt-28 md:pb-44">

      <!-- Eyebrow -->
      <div class="eyebrow mb-7 animate-slide-up">
        <span class="amber-line"></span>
        AI Automation Advisory
        <span
          class="inline-block w-px h-3 bg-surface-700 mx-1"
          aria-hidden="true"
        ></span>
        Powered by COCO AI
      </div>

      <!-- Headline — full Bebas Neue, two-tone -->
      <h1
        class="font-display uppercase leading-[0.92] text-surface-950 animate-slide-up delay-100"
        style="font-size: clamp(3.8rem, 10.5vw, 9.5rem); letter-spacing: 0.01em; max-width: 14ch;"
      >
        Your Business<br />
        Runs Itself.<br />
        <span
          class="text-brand-500"
          style="display: inline-block; text-shadow: 0 0 60px oklch(0.78 0.17 75 / 0.30);"
        >
          We Show<br class="sm:hidden" /> You How.
        </span>
      </h1>

      <!-- Sub-headline — slightly offset right on large screens for asymmetry -->
      <p
        class="mt-8 text-base md:text-lg text-surface-900 max-w-lg md:max-w-xl leading-relaxed font-light animate-slide-up delay-200 md:ml-4"
      >
        Edge of Company maps your workflows, identifies your highest-value automation wins, and connects you with
        <strong class="font-semibold text-surface-950">COCO AI agent teams</strong> that run 24/7 —
        deployed in days, not quarters.
      </p>

      <!-- CTAs -->
      <div class="mt-9 flex flex-wrap gap-3 items-center animate-slide-up delay-300">
        <a
          href="mailto:info@edgeof.xyz?subject=Free%20Automation%20Assessment%20Request"
          class="btn-primary"
        >
          Book a Free Automation Assessment
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="#how-it-works" class="btn-ghost">
          See How It Works
        </a>
      </div>

      <!-- Micro-proof row — wraps gracefully on mobile -->
      <div class="mt-10 flex flex-wrap items-center gap-x-7 gap-y-3 animate-slide-up delay-400">
        {[
          '30-minute call — no pitch',
          '1,001 proven AI use cases',
          'AI agent teams from $99/mo',
        ].map((item) => (
          <div class="flex items-center gap-2 text-sm text-surface-800">
            <svg class="w-3.5 h-3.5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            {item}
          </div>
        ))}

        <!-- Powered-by badge — separate line on mobile -->
        <a
          href="https://coco.xyz"
          target="_blank"
          rel="noopener noreferrer"
          class="powered-badge"
          aria-label="Powered by COCO AI — opens coco.xyz"
        >
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
          </svg>
          Powered by COCO AI
        </a>
      </div>

    </div>

    <!-- Bottom fade into problem section -->
    <div class="hero-fade-bottom" aria-hidden="true"></div>
  </section>


  <!-- ================================================================
       THE PROBLEM — 3 pain cards
       Left-aligned header, full-width card grid
  ================================================================ -->
  <section id="problem" class="bg-surface-50 py-20 md:py-28 relative">
    <div class="absolute top-0 left-0 right-0" aria-hidden="true"><div class="section-separator"></div></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-2xl mb-14 animate-fade-in">
        <div class="eyebrow mb-5">
          <span class="amber-line"></span>
          Sound Familiar?
        </div>
        <h2
          class="font-display uppercase text-surface-950 leading-[0.93]"
          style="font-size: clamp(2.4rem, 5.5vw, 5rem); letter-spacing: 0.01em;"
        >
          Your Business Is<br />
          <span class="text-brand-500">Hemorrhaging Hours</span><br />
          Every Single Week
        </h2>
      </div>

      <!-- Pain cards — left-border accent, no uniform card-dark class to avoid hover conflict -->
      <div class="grid md:grid-cols-3 gap-5">

        <div class="card-problem p-7 rounded-r-lg animate-fade-in delay-100">
          <div class="icon-badge mb-5">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="font-display text-[1.65rem] text-surface-950 uppercase leading-tight mb-3" style="letter-spacing: 0.02em;">
            Drowning in Repetitive Work
          </h3>
          <p class="text-surface-900 font-light text-sm leading-relaxed">
            Data entry, follow-ups, report generation, scheduling — your team burns hours daily on work that adds no creative or strategic value. Every hour costs you money and kills morale.
          </p>
          <div class="mt-5 pt-5 border-t border-surface-300/30">
            <p class="text-xs text-brand-400 font-bold tracking-[0.18em] uppercase">
              23 hrs/week per employee — lost to tasks AI handles in seconds
            </p>
          </div>
        </div>

        <div class="card-problem p-7 rounded-r-lg animate-fade-in delay-200">
          <div class="icon-badge mb-5">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
          </div>
          <h3 class="font-display text-[1.65rem] text-surface-950 uppercase leading-tight mb-3" style="letter-spacing: 0.02em;">
            Can't Scale Without More Headcount
          </h3>
          <p class="text-surface-900 font-light text-sm leading-relaxed">
            Every new client or project means another hire. Your headcount grows faster than margin. AI agent teams break this equation entirely — they scale in minutes, work nights and weekends, and cost a fraction of a full-time employee.
          </p>
          <div class="mt-5 pt-5 border-t border-surface-300/30">
            <p class="text-xs text-brand-400 font-bold tracking-[0.18em] uppercase">
              AI agents = 24/7 output at ~10% of the cost of a hire
            </p>
          </div>
        </div>

        <div class="card-problem p-7 rounded-r-lg animate-fade-in delay-300">
          <div class="icon-badge mb-5">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
            </svg>
          </div>
          <h3 class="font-display text-[1.65rem] text-surface-950 uppercase leading-tight mb-3" style="letter-spacing: 0.02em;">
            No Idea Where AI Actually Fits
          </h3>
          <p class="text-surface-900 font-light text-sm leading-relaxed">
            The AI landscape is loud with tools, hype, and contradictory advice. You know automation is coming, but you don't know what to trust, what to implement first, or how to do it without disrupting what already works.
          </p>
          <div class="mt-5 pt-5 border-t border-surface-300/30">
            <p class="text-xs text-brand-400 font-bold tracking-[0.18em] uppercase">
              Our free assessment gives you a concrete answer — in 30 minutes
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ================================================================
       HOW IT WORKS — 3-step process
       Centered header, ghost step numbers, amber connector
  ================================================================ -->
  <section id="how-it-works" class="bg-surface-100 py-20 md:py-32 relative">
    <div class="absolute top-0 left-0 right-0" aria-hidden="true"><div class="section-separator"></div></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header — centred -->
      <div class="text-center mb-20 animate-fade-in">
        <div class="eyebrow justify-center mb-5">
          <span class="amber-line"></span>
          How It Works
          <span class="amber-line"></span>
        </div>
        <h2
          class="font-display uppercase text-surface-950 leading-[0.93]"
          style="font-size: clamp(2.4rem, 5.5vw, 5.5rem); letter-spacing: 0.01em;"
        >
          Three Steps From<br />
          <span class="text-brand-500">Manual to Automated</span>
        </h2>
        <p class="mt-6 text-surface-900 font-light text-base max-w-lg mx-auto leading-relaxed">
          No technical expertise needed. No disruption to live operations. Just a guided path from your current workflow to one that runs itself.
        </p>
      </div>

      <!-- Steps — relative container for the connector line + ghost numbers -->
      <div class="relative">
        <!-- Amber connector line — desktop only -->
        <div class="process-connector hidden md:block" aria-hidden="true"></div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative z-10">

          <!-- Step 01 -->
          <div class="relative overflow-visible animate-fade-in delay-100">
            <!-- Ghost number sits behind the card -->
            <div class="step-ghost" aria-hidden="true">01</div>
            <div class="card-dark p-7 md:p-8 relative z-10 h-full flex flex-col">
              <div class="flex items-center gap-3 mb-6">
                <div
                  class="w-11 h-11 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0"
                  style="box-shadow: 0 0 0 4px oklch(0.17 0.040 256), 0 0 20px oklch(0.78 0.17 75 / 0.25);"
                >
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="oklch(0.11 0.025 258)" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                  </svg>
                </div>
                <span class="badge-amber">Step 01</span>
              </div>
              <h3
                class="font-display uppercase text-surface-950 leading-tight mb-3"
                style="font-size: 1.85rem; letter-spacing: 0.02em;"
              >
                Free Assessment
              </h3>
              <p class="text-surface-900 font-light text-sm leading-relaxed flex-1">
                We map your workflows in a focused 30-minute session and identify your top 3 automation opportunities — ranked by time saved, revenue impact, and deployment speed. Not generic advice. Specific, named wins for your operations.
              </p>
              <div class="mt-6 flex items-center gap-2 text-xs text-brand-400 font-bold tracking-[0.15em] uppercase">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                30 min · Free · Zero obligation
              </div>
            </div>
          </div>

          <!-- Step 02 -->
          <div class="relative overflow-visible animate-fade-in delay-200">
            <div class="step-ghost" aria-hidden="true">02</div>
            <div class="card-dark p-7 md:p-8 relative z-10 h-full flex flex-col">
              <div class="flex items-center gap-3 mb-6">
                <div
                  class="w-11 h-11 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0"
                  style="box-shadow: 0 0 0 4px oklch(0.17 0.040 256), 0 0 20px oklch(0.78 0.17 75 / 0.25);"
                >
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="oklch(0.11 0.025 258)" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" />
                  </svg>
                </div>
                <span class="badge-amber">Step 02</span>
              </div>
              <h3
                class="font-display uppercase text-surface-950 leading-tight mb-3"
                style="font-size: 1.85rem; letter-spacing: 0.02em;"
              >
                AI Team Design
              </h3>
              <p class="text-surface-900 font-light text-sm leading-relaxed flex-1">
                We match your needs to the right COCO AI agent configuration from 1,001 proven enterprise use cases. You receive a concrete deployment plan — which agents handle which tasks, how they integrate with your tools, and what results to expect in week one.
              </p>
              <div class="mt-6 flex items-center gap-2 text-xs text-brand-400 font-bold tracking-[0.15em] uppercase">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
                Matched to your exact workflow
              </div>
            </div>
          </div>

          <!-- Step 03 -->
          <div class="relative overflow-visible animate-fade-in delay-300">
            <div class="step-ghost" aria-hidden="true">03</div>
            <div class="card-dark p-7 md:p-8 relative z-10 h-full flex flex-col">
              <div class="flex items-center gap-3 mb-6">
                <div
                  class="w-11 h-11 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0"
                  style="box-shadow: 0 0 0 4px oklch(0.17 0.040 256), 0 0 20px oklch(0.78 0.17 75 / 0.25);"
                >
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="oklch(0.11 0.025 258)" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
                  </svg>
                </div>
                <span class="badge-amber">Step 03</span>
              </div>
              <h3
                class="font-display uppercase text-surface-950 leading-tight mb-3"
                style="font-size: 1.85rem; letter-spacing: 0.02em;"
              >
                Deploy &amp; Win
              </h3>
              <p class="text-surface-900 font-light text-sm leading-relaxed flex-1">
                Your AI employees go live in days. We handle the full handoff to COCO AI's deployment team and stay involved until results land. This is not a referral — it's a guided transformation with a named account manager on every step.
              </p>
              <div class="mt-6 flex items-center gap-2 text-xs text-brand-400 font-bold tracking-[0.15em] uppercase">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7Z" />
                </svg>
                Live in days, not quarters
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Mid-section CTA nudge -->
      <div class="text-center mt-14 animate-fade-in delay-400">
        <a
          href="mailto:info@edgeof.xyz?subject=Free%20Automation%20Assessment%20Request"
          class="btn-primary inline-flex"
        >
          Start with a Free Assessment
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <p class="mt-3 text-xs text-surface-800 tracking-wide">Free 30-minute call. Real answers. Zero fluff.</p>
      </div>

    </div>
  </section>


  <!-- ================================================================
       PROOF / STATS — live dashboard tiles
       Asymmetric 2-col header + 2×2 proof grid
  ================================================================ -->
  <section id="proof" class="bg-surface-50 py-20 md:py-28 relative">
    <div class="absolute top-0 left-0 right-0" aria-hidden="true"><div class="section-separator"></div></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header — left/right split -->
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14 animate-fade-in">
        <div>
          <div class="eyebrow mb-5">
            <span class="amber-line"></span>
            Documented Results
          </div>
          <h2
            class="font-display uppercase text-surface-950 leading-[0.93]"
            style="font-size: clamp(2.4rem, 5.5vw, 5rem); letter-spacing: 0.01em;"
          >
            Numbers Don't Lie.<br />
            <span class="text-brand-500">Automation Works.</span>
          </h2>
        </div>
        <p class="text-surface-900 font-light text-sm max-w-xs lg:text-right leading-relaxed lg:mb-2">
          These aren't projections. Every figure below is a documented outcome from a live COCO AI deployment — in sectors just like yours.
        </p>
      </div>

      <!-- Proof grid — 2×2, each a "dashboard tile" -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

        <!-- Tile 1 — Bank -->
        <div class="proof-card animate-fade-in delay-100">
          <div class="flex items-start justify-between mb-5">
            <span class="badge-amber">Financial Services</span>
            <svg class="w-5 h-5 text-surface-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
            </svg>
          </div>

          <!-- "Before → After" stat display -->
          <div class="flex items-baseline flex-wrap gap-x-3 gap-y-1 mb-5">
            <span
              class="font-display stat-glow leading-none"
              style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
            >3 Days</span>
            <svg class="w-5 h-5 text-brand-500 flex-shrink-0 self-center" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-label="reduced to" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
            <span
              class="font-display text-surface-950 leading-none"
              style="font-size: clamp(2rem, 4.5vw, 3.5rem);"
            >2 Hours</span>
          </div>

          <p class="text-surface-950 font-semibold text-sm mb-2 leading-snug">
            Loan due diligence at a major state-owned bank
          </p>
          <p class="text-surface-800 text-sm font-light leading-relaxed">
            Full loan application reviews that took analysts three days now complete in under two hours — higher accuracy, full audit trail, zero additional headcount.
          </p>
        </div>

        <!-- Tile 2 — Dev team -->
        <div class="proof-card animate-fade-in delay-200">
          <div class="flex items-start justify-between mb-5">
            <span class="badge-amber">Technology</span>
            <svg class="w-5 h-5 text-surface-700" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          </div>
          <div class="flex items-baseline flex-wrap gap-x-3 gap-y-1 mb-5">
            <span
              class="font-display stat-glow leading-none"
              style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
            >10×</span>
            <span class="text-surface-900 font-light text-base self-center">faster releases</span>
          </div>
          <p class="text-surface-950 font-semibold text-sm mb-2 leading-snug">
            Engineering team of 6, using COCO AI agent teams
          </p>
          <p class="text-surface-800 text-sm font-light leading-relaxed">
            AI agents handled code review, testing, and deployment pipelines. Release cadence went from biweekly to daily — same headcount, ten times the output.
