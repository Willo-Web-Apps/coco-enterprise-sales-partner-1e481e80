---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Your New Business", description = "Create a sales organization, landing page and strategy dedicated to helping the Edge of Compay (www.edgeof.xyz) to sell coco.xyz to enterprises and other potential clients to automate their businesses.  Coco has hired edge to generate qualified leads and get meetings.  Build our business around helping their business.  Decide when and how to refer people to coco using our affiliate link so there is no leakage." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Your New Business",
      "description": "Create a sales organization, landing page and strategy dedicated to helping the Edge of Compay (www.edgeof.xyz) to sell coco.xyz to enterprises and other potential clients to automate their businesses.  Coco has hired edge to generate qualified leads and get meetings.  Build our business around helping their business.  Decide when and how to refer people to coco using our affiliate link so there is no leakage.",
      "url": "https://coco-enterprise-sales-partner.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
